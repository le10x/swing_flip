{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "le10x.double_click_pause_buttons",
    "name": "Double Click Pause Buttons",
    "developer": "le10x",
    "version": "v1.0.0",
    "description": "A mod that requires quick clicking to activate the pause menu buttons!",
    "repository": "https://github.com",
    "settings": {
       "show-message": { "name": "Show Confirmation Message", "type": "bool", "default": true },
        "custom-text": { "name": "Custom Message Text", "type": "string", "default": "Click again to confirm" },
        "message-opacity": { "name": "Message Opacity (0-100)", "type": "int", "default": 80, "min": 0, "max": 100 },
        "use-gold-font": { "name": "Use Gold Font", "type": "bool", "default": false },
        "click-speed": { 
            "name": "Double Tap Speed", 
            "type": "int", 
            "default": 500,
            "one-of": [250, 500, 750, 1000],
            "controls": "arrows"
        },
        "min-percent": { "name": "Min Percent Activation (0-100)", "type": "int", "default": 0, "min": 0, "max": 100 },
        "lock-exit": { "name": "Protect Exit Button", "type": "bool", "default": true },
        "lock-reset": { "name": "Protect Reset Button", "type": "bool", "default": true },
        "lock-practice-all": { "name": "Protect Practice Buttons", "type": "bool", "default": false },
        "lock-reset-plat": { "name": "Protect Reset All (Plat)", "type": "bool", "default": false }
    }
}
